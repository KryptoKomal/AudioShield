{
  "manifest_version": 3,
  "name": "DeepShield Audio",
  "version": "1.0.0",
  "description": "Production-ready Chrome Extension to detect whether audio in a tab or a file is real or AI-generated.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "DeepShield Audio Scanner"
  },
  "permissions": [
    "activeTab",
    "tabCapture",
    "storage",
    "offscreen"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "host_permissions": [
    "http://localhost:3000/*"
  ]
}
